{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/_/backend/api/:path*"
    }
  ],
  "experimentalServices": {
    "frontend": {
      "entrypoint": "Frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "Backend",
      "routePrefix": "/_/backend",
      "framework": "express"
    }
  }
}
