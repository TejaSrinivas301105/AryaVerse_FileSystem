# ============================
# Cloud Core Backend .env
# ============================
# Copy this file to `.env` and replace all placeholder values.
# Do not commit your real `.env` file.

# ----------------------------
# Supabase (required)
# ----------------------------
# Example: https://abcd1234.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service role key (server-side only, keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------
# SMTP Auth (required for email notifications)
# ----------------------------
# Mailbox/login used by Nodemailer SMTP auth
EMAIL=verify@your-domain.com

# IMAP/SMTP password or app password for the mailbox above
PASSWORD=your-imap-smtp-password

# ----------------------------
# SMTP Transport (Lark defaults)
# ----------------------------
# Lark SMTP host
SMTP_HOST=smtp.larksuite.com

# SSL port: 465 (recommended)
# STARTTLS alternative: 587 (set SMTP_SECURE=false if using 587)
SMTP_PORT=465

# true for port 465, false for port 587
SMTP_SECURE=true

# Sender email shown in outgoing notifications
# Usually same as EMAIL
EMAIL_FROM=verify@your-domain.com

# ----------------------------
# Frontend Origin (required for CORS)
# ----------------------------
# Local example: http://localhost:5173
# Production example: https://www.beingcosmic.com
# IMPORTANT: no trailing slash
FRONTEND_URL=https://www.beingcosmic.com
